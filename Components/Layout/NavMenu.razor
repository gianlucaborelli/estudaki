@inherits NavMenuBase

@using ProvaOnline.Components.Layout

<style>
    .mud-item {
        margin-left: 10px;
        margin-right: 10px;
    }
</style>

<MudNavMenu>

    <MudGrid>
        <MudItem xs="12" Style="margin-left: 10px; margin-right: 10px;">
            <MudText Align="Align.Center" Typo="Typo.h6" Style="margin-top:10px">Termos para pesquisa</MudText>
            <MudTextField Margin="Margin.Dense"
                          @bind-Value="_wordKey" 
                          Clearable="true"
                          Label="Palavra chave" 
                          Variant="Variant.Outlined" />
        </MudItem>

        <MudItem xs="12" Style="margin-left: 10px; margin-right: 10px;">
            <MudSelectExtended T="string"
                               ItemCollection="_questionType"
                               @bind-SelectedValues="_questionTypeSelected"
                               MultiSelection="true"
                               Margin="Margin.Dense"
                               SearchBox="true"
                               Label="Tipo de Prova"
                               AnchorOrigin="Origin.BottomCenter"
                               Variant="Variant.Outlined"
                               Clearable="true"
                               SearchBoxClearable="true" />
        </MudItem>

        <MudItem xs="12" Style="margin-left: 10px; margin-right: 10px;">
            <MudSelectExtended T="string"
                               ItemCollection="_mainArea"
                               @bind-SelectedValues="_mainAreaSelected"
                               MultiSelection="true"
                               Margin="Margin.Dense"
                               SearchBox="true"
                               Label="Área de conhecimento"
                               AnchorOrigin="Origin.BottomCenter"
                               Variant="Variant.Outlined"
                               Clearable="true"
                               SearchBoxClearable="true" />
        </MudItem>

        <MudItem xs="12" Style="margin-left: 10px; margin-right: 10px;">
            <MudSelectExtended T="string"
                               ItemCollection="_subArea"
                               @bind-SelectedValues="_subAreaSelected"
                               MultiSelection="true"
                               OnClearButtonClick="LoadingFilterParameters"
                               OnClose="LoadingFilterParameters"
                               Margin="Margin.Dense"
                               SearchBox="true"
                               Label="Subárea do conhecimento"
                               AnchorOrigin="Origin.BottomCenter"
                               Variant="Variant.Outlined"
                               Clearable="true"
                               SearchBoxClearable="true" />
        </MudItem>

        <MudItem xs="12"
                 Style="margin-left: 10px; margin-right: 10px;display: flex; justify-content:center">
            <MudFab StartIcon="@Icons.Material.Filled.Search"
                    Label="Pesquisar"
                    OnClick="SearchQuestions" />
        </MudItem>

    </MudGrid>
</MudNavMenu>
