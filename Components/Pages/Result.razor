@page "/result"
@using ProvaOnline.Components.Elements
@using ProvaOnline.Components.Shared
@using ProvaOnline.Models
@inherits ResultBase

<PageTitle>Resultados da Busca - EstudaKi</PageTitle>

<SeoHead 
    Title="Resultados da Busca - EstudaKi"
    Description="Explore questões filtradas de vestibulares, concursos públicos e OAB. Pratique e aprimore seus conhecimentos gratuitamente."
    Keywords="questões vestibular, questões concurso, questões OAB, busca questões, filtro questões"
    CanonicalUrl="https://estudaki.com.br/result" />

<MudGrid >
    <MudItem xs="12"
             Style="display: flex; justify-content:center">
        <MudPagination Color="Color.Primary"
                       Count="@TotalPages" @bind-Selected="@CurrentPage"
                       Variant="Variant.Text"
                       BoundaryCount="@BoundaryCount"
                       ShowFirstButton="true"
                       ShowLastButton="true"
                       Class="mt-4" />
    </MudItem>    

    @foreach (QuestionDocument question in Questions)
    {
        <MudItem xs="12">
            <QuestionComponent Value="question" />
        </MudItem>
    }

    <MudItem xs="12"
             Style="display: flex; justify-content:center">
        <MudPagination Color="Color.Primary"
                       Count="@TotalPages" @bind-Selected="@CurrentPage"
                       Variant="Variant.Text"
                       BoundaryCount="1"
                       ShowFirstButton="true"
                       ShowLastButton="true"
                       Class="mt-4" />
    </MudItem>
</MudGrid>