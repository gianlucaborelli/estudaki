@page "/result"
@using ProvaOnline.Components.Elements
@using ProvaOnline.Models
@inherits ResultBase

<MudGrid >
    <MudItem xs="12"
             Style="display: flex; justify-content:center">
        <MudPagination Color="Color.Primary"
                       Count="@TotalPages" @bind-Selected="@CurrentPage"
                       Variant="Variant.Text"
                       BoundaryCount="@BoundaryCount"
                       ShowFirstButton="true"
                       ShowLastButton="true"
                       Class="mt-4" />
    </MudItem>    

    @foreach (QuestionDocument question in Questions)
    {
        <MudItem xs="12">
            <QuestionComponent Value="question" />
        </MudItem>
    }

    <MudItem xs="12"
             Style="display: flex; justify-content:center">
        <MudPagination Color="Color.Primary"
                       Count="@TotalPages" @bind-Selected="@CurrentPage"
                       Variant="Variant.Text"
                       BoundaryCount="1"
                       ShowFirstButton="true"
                       ShowLastButton="true"
                       Class="mt-4" />
    </MudItem>
</MudGrid>